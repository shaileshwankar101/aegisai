# ─────────────────────────────────────────────────────────────
# AegisAI — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to GitHub — it contains secrets
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=aegisai
POSTGRES_USER=aegisai
POSTGRES_PASSWORD=change_this_strong_password

# ── Langfuse Cloud (Japan region) ────────────────────────────
# Get these from: langfuse.com → aegisai org → vendor-risk-copilot → Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Grafana Dashboard ─────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_this_strong_password

# ── Ollama Model ──────────────────────────────────────────────
# Options: phi3:mini (fast dev), qwen2.5:7b (eval), llama3.1:8b, mistral:7b
OLLAMA_MODEL=phi3:mini

# ── RAG Configuration (baseline — change for experiments) ─────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5
SIMILARITY_THRESHOLD=0.75

# ── Prompt Versioning ─────────────────────────────────────────
PROMPT_VERSION=v1.0

# ── App Settings ──────────────────────────────────────────────
LOG_LEVEL=INFO
